  "testCases": [
    { "input": "aaabbc", "expected": "a3b2c1", "visible": true },
    { "input": "wwwwaaadexxxxxx", "expected": "w4a3d1e1x6", "visible": true },
    { "input": "a", "expected": "a1", "visible": false },
    { "input": "abcd", "expected": "a1b1c1d1", "visible": false },
    { "input": "aaa", "expected": "a3", "visible": false }
  ],
